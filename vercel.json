{
  "version": 2,
  "installCommand": "npm install --prefix backend && npm install --prefix \"frontend/financial web\"",
  "buildCommand": "npm run build --prefix \"frontend/financial web\"",
  "outputDirectory": "frontend/financial web/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
